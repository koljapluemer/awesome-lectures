{% extends "base.html.jinja2" %}

{% block title %}{{ lecture.title }} — Awesome Lectures{% endblock %}

{% block content %}
<div class="container py-lg">
  <div class="flex items-center gap-md mt-md mb-sm">
    <h1 class="text-2xl font-bold" style="flex:1;">{{ lecture.title }}</h1>
    <button class="icon-btn" data-slug="{{ lecture.slug }}" data-action="like" aria-label="Like"><i data-lucide="heart" width="20" height="20"></i></button>
    <button class="icon-btn" data-slug="{{ lecture.slug }}" data-action="seen" aria-label="Mark as seen"><i data-lucide="eye" width="20" height="20"></i></button>
  </div>

  {% if lecture.speakers %}
  <div class="text-md text-muted mb-md">{{ lecture.speakers | join(", ") }}</div>
  {% endif %}

  {% if lecture.topics or lecture.tags %}
  <div class="flex flex-wrap gap-sm mb-md">
    {% for t in (lecture.topics or []) + (lecture.tags or []) %}
    <span class="tag">{{ t }}</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if lecture.video_id and lecture.embed %}
  <div class="video-wrapper mb-lg">
    <iframe src="https://www.youtube.com/embed/{{ lecture.video_id }}"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
    </iframe>
  </div>
  {% elif lecture.thumbnail and lecture.urls %}
  <a href="{{ lecture.urls[0] }}" target="_blank" rel="noopener" class="mb-lg" style="display:inline-block;">
    <img src="{{ root }}{{ lecture.thumbnail }}" alt="{{ lecture.title }}" style="border-radius:0.5rem; max-width:400px; width:100%; display:block;">
  </a>
  {% endif %}
  {% if lecture.urls %}
  <div class="mb-md flex flex-col gap-sm">
    {% for url in lecture.urls %}
    <a href="{{ url }}" target="_blank" rel="noopener">{{ url }}</a>
    {% endfor %}
  </div>
  {% endif %}

  <div class="card flex flex-col gap-sm">
    {% if lecture.worthWatchingWithoutVideo is not none %}
    <div class="text-sm"><span class="text-muted">Worth watching without video:</span> {{ lecture.worthWatchingWithoutVideo }}/10</div>
    {% endif %}
    {% if lecture.beginnerExpertSpectrum %}
    <div class="text-sm"><span class="text-muted">Beginner–expert level:</span> {{ lecture.beginnerExpertSpectrum[0] }}/10</div>
    {% endif %}
    {% if lecture.liked %}
    <div class="text-sm"><span class="text-muted">Liked:</span> {{ lecture.liked[0] }}/100</div>
    {% endif %}
  </div>

  {% if lecture.learnings %}
  {% macro learning_card(item) %}
  {% set color = item.key | hue_from_str %}
  {% set spread = [item.spread | default(0), 0.1] | max %}
  {% set l = ([item.rating - spread, 0]  | max) * 10 %}
  {% set r = ([item.rating + spread, 10] | min) * 10 %}
  {% set m = item.rating * 10 %}
  {% set c_l = color | mix_white(l / 100) %}
  {% set c_r = color | mix_white(r / 100) %}
  <div class="card" style="padding:0.5rem 0.75rem;display:flex;align-items:stretch;gap:0.75rem;">
    <div style="flex:1;">
      <div class="text-sm font-bold mb-xs">{{ item.key }}</div>
      <div style="position:relative;height:16px;border-radius:4px;overflow:hidden;background:linear-gradient(to right,#d4d4d4 0%,#d4d4d4 {{ l }}%,{{ c_l }} {{ l }}%,{{ c_r }} {{ r }}%,#d4d4d4 {{ r }}%,#d4d4d4 100%);">
        <div style="position:absolute;left:{{ m }}%;top:0;bottom:0;width:2px;background:#111;transform:translateX(-50%);"></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;padding-left:0.75rem;border-left:1px solid var(--border);font-weight:700;font-size:0.95rem;flex-shrink:0;min-width:2.8rem;justify-content:center;">{{ item.rating | round(1) }}</div>
  </div>
  {% endmacro %}
  {% set all_items = lecture.learnings | sorted_learnings %}
  {% set above = all_items | selectattr('rating', 'ge', 5) | list %}
  {% set below = all_items | rejectattr('rating', 'ge', 5) | list %}
  <h2 class="text-lg font-bold mt-lg mb-sm">Watch this if you want to...</h2>
  <div class="flex flex-col gap-sm">
    {% for item in above %}{{ learning_card(item) }}{% endfor %}
    {% if below %}
    <details>
      <summary class="text-sm text-muted" style="cursor:pointer;user-select:none;">{{ below | length }} lower-rated {{ 'learning' if below | length == 1 else 'learnings' }}</summary>
      <div class="flex flex-col gap-sm mt-sm">
        {% for item in below %}{{ learning_card(item) }}{% endfor %}
      </div>
    </details>
    {% endif %}
  </div>
  {% endif %}
</div>
{% endblock %}
