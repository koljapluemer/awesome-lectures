{% extends "base.html.jinja2" %}

{% block title %}Submit a Lecture — Awesome Lectures{% endblock %}

{% block head %}
<style>
  .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
  label { font-size: 0.875rem; font-weight: 700; }
  label .optional { font-weight: 400; color: var(--text-muted); }
  input[type="text"], input[type="url"], textarea {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--text);
    width: 100%;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  textarea { resize: vertical; min-height: 80px; }
  .hint { font-size: 0.8rem; color: var(--text-muted); }
  .submit-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    padding: 0.6rem 1.5rem;
    font-size: 1rem;
    cursor: pointer;
    align-self: flex-start;
  }
  .submit-btn:hover { background: var(--accent-hover); }
</style>
{% endblock %}

{% block content %}
<div class="container py-lg" style="max-width:600px;">
  <h1 class="text-2xl font-bold mb-sm">Submit a Lecture</h1>
  <p class="text-sm text-muted mb-lg">Know a great talk? Submit it for review and we'll add it to the collection.</p>

  <form action="https://api.staticforms.xyz/submit" method="post" class="flex flex-col gap-md">
    <input type="hidden" name="accessKey" value="{{ staticforms_key }}">
    <input type="hidden" name="redirectTo" value="{{ site_url }}submit/thanks/">
    <input type="hidden" name="subject" value="New lecture submission">
    <input type="text" name="$honeypot" style="display:none;" tabindex="-1" autocomplete="off">

    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required placeholder="e.g. The Art of Doing Science and Engineering">
    </div>

    <div class="form-group">
      <label for="url">URL <span class="optional">(YouTube, Vimeo, conference site, …)</span></label>
      <input type="url" id="url" name="url" required placeholder="https://...">
    </div>

    <div class="form-group">
      <label for="speakers">Speakers <span class="optional">(optional)</span></label>
      <input type="text" id="speakers" name="speakers" placeholder="e.g. Richard Hamming, Judy Fan">
    </div>

    <div class="form-group">
      <label for="topics">Topics <span class="optional">(optional)</span></label>
      <input type="text" id="topics" name="topics" placeholder="e.g. machine-learning, game-design">
      <span class="hint">Comma-separated</span>
    </div>

    <div class="form-group">
      <label for="notes">Notes <span class="optional">(optional)</span></label>
      <textarea id="notes" name="notes" placeholder="Why is this lecture worth watching?"></textarea>
    </div>

    <button type="submit" class="submit-btn">Submit &rarr;</button>
  </form>
</div>
{% endblock %}
