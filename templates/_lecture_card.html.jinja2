{% macro lecture_card(lecture, root) %}
<div class="card lecture-card">
  <a href="{{ root }}lectures/{{ lecture.slug }}.html" class="lecture-link">
    <img src="{{ root }}{{ lecture.thumbnail }}" alt="" width="120" style="border-radius:0.375rem; flex-shrink:0; object-fit:cover;">
    <div>
      <div class="text-lg font-bold">{{ lecture.title }}</div>
      {% if lecture.speakers %}
      <div class="text-sm text-muted mt-sm">{{ lecture.speakers | join(", ") }}</div>
      {% endif %}
      {% set all_tags = (lecture.topics or []) + (lecture.tags or []) %}
      {% if all_tags %}
      <div class="flex flex-wrap gap-sm mt-sm">
        {% for t in all_tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
      {% endif %}
    </div>
  </a>
  {% if lecture.learnings %}
  {% set top_learnings = lecture.learnings | sorted_learnings | selectattr('rating', 'ge', 5) | list %}
  {% if top_learnings %}
  <div class="lecture-learnings">
    {% for item in top_learnings[:3] %}
    {% set color = item.key | hue_from_str %}
    {% set spread = [item.spread | default(0), 0.1] | max %}
    {% set l = ([item.rating - spread, 0] | max) * 10 %}
    {% set r = ([item.rating + spread, 10] | min) * 10 %}
    {% set m = item.rating * 10 %}
    {% set c_l = color | mix_white(l / 100) %}
    {% set c_r = color | mix_white(r / 100) %}
    <div>
      <div style="font-size:0.7rem;color:var(--text-muted);word-break:break-word;margin-bottom:0.2rem;">{{ item.key }}</div>
      <div style="display:flex;align-items:center;gap:0.35rem;">
        <div style="flex:1;position:relative;height:8px;border-radius:3px;overflow:hidden;background:linear-gradient(to right,#d4d4d4 0%,#d4d4d4 {{ l }}%,{{ c_l }} {{ l }}%,{{ c_r }} {{ r }}%,#d4d4d4 {{ r }}%,#d4d4d4 100%);">
          <div style="position:absolute;left:{{ m }}%;top:0;bottom:0;width:1px;background:#111;transform:translateX(-50%);"></div>
        </div>
        <span style="font-size:0.7rem;font-weight:700;width:1.8rem;text-align:right;flex-shrink:0;">{{ item.rating | round(1) }}</span>
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% endif %}
  <div class="lecture-actions">
    <button class="icon-btn" data-slug="{{ lecture.slug }}" data-action="like" aria-label="Like"><i data-lucide="heart" width="18" height="18"></i></button>
    <button class="icon-btn" data-slug="{{ lecture.slug }}" data-action="seen" aria-label="Mark as seen"><i data-lucide="eye" width="18" height="18"></i></button>
  </div>
</div>
{% endmacro %}
