<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Awesome Lectures{% endblock %}</title>
  <link rel="stylesheet" href="{{ root }}styles.css">
  <link rel="icon" href="{{ root }}favicon.ico">
  <style>
    header {
      border-bottom: 1px solid var(--border);
      background: var(--bg-card);
    }
    header .inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header a { color: var(--text); text-decoration: none; }
    header a:hover { color: var(--accent); text-decoration: none; }
    .header-nav { display: flex; gap: 1.5rem; align-items: center; }
  </style>
  <style>
    .icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;
      color: var(--text-muted);
      border-radius: 0.25rem;
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }
    .icon-btn:hover { color: var(--text); }
    .icon-btn[data-action="like"].active  { color: #e05575; }
    .icon-btn[data-action="like"].active svg  { fill: #e05575; }
    .icon-btn[data-action="seen"].active  { color: var(--accent); }
    .icon-btn[data-action="seen"].active svg  { fill: var(--accent); }
  </style>
  {% block head %}{% endblock %}
</head>
<body>
  <header>
    <div class="inner">
      <a href="{{ root }}"><img src="{{ root }}logo.png" alt="Awesome Lectures" style="height:36px; display:block;"></a>
      <nav class="header-nav">
        <a href="{{ root }}lectures/random/" class="text-sm">Browse</a>
        <a href="{{ root }}search/" class="text-sm">Search</a>
        <a href="{{ root }}submit/" class="text-sm">Submit</a>
      </nav>
    </div>
  </header>

  <main>
    {% block content %}{% endblock %}
  </main>

  <div id="toast-rack"></div>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    const AL_API_BASE = {{ api_base | tojson }};

    lucide.createIcons();
    const KEYS = { like: 'al_likes', seen: 'al_seen' };
    function getSet(k) { return new Set(JSON.parse(localStorage.getItem(k) || '[]')); }
    function saveSet(k, s) { localStorage.setItem(k, JSON.stringify([...s])); }
    function refreshBtn(btn) {
      const active = getSet(KEYS[btn.dataset.action]).has(btn.dataset.slug);
      btn.classList.toggle('active', active);
    }
    function toast(msg, isError) {
      const el = document.createElement('div');
      el.className = 'toast' + (isError ? ' error' : '');
      el.textContent = msg;
      document.getElementById('toast-rack').appendChild(el);
      requestAnimationFrame(() => requestAnimationFrame(() => el.classList.add('show')));
      setTimeout(() => {
        el.classList.remove('show');
        el.addEventListener('transitionend', () => el.remove(), { once: true });
      }, isError ? 4000 : 2000);
    }
    function getFingerprint() {
      let fp = localStorage.getItem('al_fp');
      if (!fp) { fp = crypto.randomUUID(); localStorage.setItem('al_fp', fp); }
      return fp;
    }
    function recordInteraction(slug, action) {
      if (AL_API_BASE === null) return;
      fetch(`${AL_API_BASE}/api/interactions/${encodeURIComponent(slug)}/${action}`, {
        method: 'POST',
        headers: { 'X-AL-Fingerprint': getFingerprint() },
      })
        .then(r => { if (r.ok) toast('vote saved'); else throw new Error(); })
        .catch(() => toast('vote could not be saved; this is probably a problem on my side', true));
    }
    document.querySelectorAll('.icon-btn').forEach(btn => {
      refreshBtn(btn);
      btn.addEventListener('click', e => {
        e.preventDefault(); e.stopPropagation();
        const s = getSet(KEYS[btn.dataset.action]);
        const wasActive = s.has(btn.dataset.slug);
        wasActive ? s.delete(btn.dataset.slug) : s.add(btn.dataset.slug);
        saveSet(KEYS[btn.dataset.action], s);
        refreshBtn(btn);
        if (!wasActive) recordInteraction(btn.dataset.slug, btn.dataset.action);
      });
    });
  </script>
  <script>
    window.goatcounter = {
      path: function (p) { return location.host + p }
    }
  </script>
  <script data-goatcounter="https://koljasam.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</body>
</html>
