<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Awesome Lectures{% endblock %}</title>
  <link rel="stylesheet" href="{{ root }}styles.css">
  <link rel="icon" href="{{ root }}favicon.ico">
  <style>
    header {
      border-bottom: 1px solid var(--border);
      background: var(--bg-card);
    }
    header .inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header a { color: var(--text); text-decoration: none; }
    header a:hover { color: var(--accent); text-decoration: none; }
    .header-nav { display: flex; gap: 1.5rem; align-items: center; }
  </style>
  {% block head %}{% endblock %}
</head>
<body>
  <header>
    <div class="inner">
      <a href="{{ root }}" class="font-bold text-md">Awesome Lectures</a>
      <nav class="header-nav">
        <a href="{{ root }}lectures/random/" class="text-sm">Browse</a>
        <a href="{{ root }}search/" class="text-sm">Search</a>
        <a href="{{ root }}submit/" class="text-sm">Submit</a>
      </nav>
    </div>
  </header>

  <main>
    {% block content %}{% endblock %}
  </main>

</body>
</html>
