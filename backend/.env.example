# Flask
SECRET_KEY=dev-secret-change-in-prod
DATABASE=lectures.db

# CORS — comma-separated origins, or * for dev
ALLOWED_ORIGINS=*

# GitHub OAuth
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Authorization callback URL: http://localhost:5000/admin/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Target repo and branch for JSON writes
GITHUB_REPO=your-username/awesome-lectures
GITHUB_BRANCH=main

# Comma-separated GitHub usernames allowed to access /admin
ALLOWED_MODERATORS=your-github-username
