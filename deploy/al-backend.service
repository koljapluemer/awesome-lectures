[Unit]
Description=Awesome Lectures Backend
After=network.target

[Service]
User=al
WorkingDirectory=/srv/awesome-lectures/backend
ExecStart=/srv/awesome-lectures/backend/.venv/bin/gunicorn -w 2 -b 0.0.0.0:5000 'app:create_app()'
Restart=on-failure
EnvironmentFile=/srv/awesome-lectures/backend/.env

[Install]
WantedBy=multi-user.target
